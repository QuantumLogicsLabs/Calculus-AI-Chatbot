# Dockerfile.aiservice - CalcVoyager AI Service
FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY aiService/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the aiService directory
COPY aiService/ ./aiService/

# Default command
CMD ["uvicorn", "aiService.chatbot:app", "--host", "0.0.0.0", "--port", "8001"]
